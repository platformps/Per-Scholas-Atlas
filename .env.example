# ============================================================================
# Per Scholas Job Intelligence — Environment Variables
# Copy to .env.local for local development. NEVER commit .env files.
# ============================================================================

# Supabase (from project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only, never exposed to client

# Database (from project Settings → Database → Connection String)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# RapidAPI — only used by the GitHub Actions worker.
# DO NOT put this in Vercel env vars unless you add an in-app fetch trigger.
RAPIDAPI_KEY=your-rapidapi-key
