  "description_disqualifiers": {
    "description": "Hard reject if description_text contains any of these phrases.",
    "credentials": [
      "p.e. license required",
      "pe license required",
      "professional engineer license required",
      "bachelor's degree required",
      "bs required",
      "four-year degree required",
      "master's degree required",
      "master electrician required",
      "master electrician license required",
      "journeyman electrician license required"
    ],
    "experience": {
      "description": "§A2: regex-based experience filter. Reject when a captured year-count > max_years_allowed AND a 'required'-class word appears within ±50 chars of the match. Patterns capture both digit and spelled-out forms; the spelled standalone pattern relies on the proximity gate to suppress incidental phrases (e.g. 'four years ago').",
      "max_years_allowed": 3,
      "patterns": [
        "(\\d+)\\)?\\+?\\s*(?:to\\s*\\d+\\s*)?years?'?\\s+(?:of\\s+)?(?:experience|exp\\b)",
        "(?:minimum|at least|requires?)\\s+(?:of\\s+)?(\\d+|three|four|five|six|seven|eight|nine|ten)\\+?\\s*years?",
        "(\\d+)\\s*[-–—]\\s*\\d+\\s*years?'?\\s+(?:of\\s+)?(?:experience|exp\\b)",
        "\\b(three|four|five|six|seven|eight|nine|ten)\\+?\\s*years?\\b",
        "\\b(\\d+)\\+\\s*years?\\b"
      ]
    }
  },

