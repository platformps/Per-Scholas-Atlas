  "experience_filter": {
    "description": "API-side filter + post-fetch tightening.",
    "api_levels_allowed": ["0-2", "2-5"],
    "auto_reject_levels": ["5-10", "10+"],
    "post_fetch_penalty": {
      "description": "If ai_experience_level is 2-5 BUT description requires >3 years, deduct 10 points.",
      "patterns": ["more than [3-9] years", "[3-9]\\+ years", "minimum [3-9] years"],
      "penalty": 10
    }
  },

  "geography": {
    "description": "Per-campus geofencing using haversine distance from campus coords against jobs' lats_derived/lngs_derived.",
    "default_radius_miles": 100
  },

  "scoring": {
    "thresholds": {
      "high": 75,
      "medium": 50,
      "low": 30
    },
    "formula": [
      "title_score (tier-based, 0-40)",
      "+ core_skills_score (count * 8, capped at 40)",
      "+ specialized_skills_score (count * 4, capped at 20)",
      "+ bonus_skills_score (count * 1, capped at 5; requires core_match >= 1 OR industry_match >= 1)",
      "+ certs_score (count * 5, capped at 15)",
      "+ industry_context_score (count * 3, capped at 10)",
      "+ employer_watchlist_score (5 if matched, else 0)",
      "- experience_penalty (10 if applicable)",
      "= raw_score",
      "",
      "Hard rejects (return REJECT regardless of score):",
      "- Any title_exclusion match",
      "- Any description_disqualifier match",
      "- Outside geographic radius",
      "- ai_experience_level in auto_reject_levels"
    ]
  },

  "tags": {
    "BAS_TRACK": {
      "description": "Strong building-automation signal regardless of title tier (e.g., a Tier A CFT role heavy in BACnet/Modbus/PLC content).",
      "rules": {
        "any_of_skills": ["BACnet", "Modbus", "PLC", "BMS/BAS", "Ladder Logic", "PID Control"],
        "min_matches": 2
      }
    },
    "HEALTHCARE_TRACK": {
      "description": "Healthcare facility employer, or strong healthcare context in title/description/industry.",
      "rules": {
        "any_of_employer_categories": ["healthcare_atlanta"],
        "any_of_phrases": ["hospital", "medical center", "healthcare facility", "health system"],
        "any_of_industries": ["hospital", "health care"]
      }
    }
